<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="?attr/selectableItemBackground">

    <!-- Scheme name + radio -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_scheme_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorPrimary" />

        <RadioButton
            android:id="@+id/rb_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:clickable="false"
            android:focusable="false"
            android:buttonTint="@color/blue_800" />

    </LinearLayout>

    <!-- Mini widget preview -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cv_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="3dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Widget title bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:id="@+id/tv_preview_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Portfolio"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_preview_refresh"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="↻"
                    android:textSize="16sp" />

            </LinearLayout>

            <View
                android:id="@+id/v_preview_divider0"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="6dp" />

            <!-- Example stock 1: gain -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_preview_name1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Apple Inc."
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_preview_price1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£182.50"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="6dp">

                <TextView
                    android:id="@+id/tv_preview_symbol1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AAPL"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tv_preview_change1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+21.7%"
                    android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_preview_total1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£18,250"
                    android:textSize="10sp" />

            </LinearLayout>

            <View
                android:id="@+id/v_preview_divider1"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginBottom="6dp" />

            <!-- Example stock 2: loss -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_preview_name2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Barclays"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:singleLine="true"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tv_preview_price2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£1.85"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_preview_symbol2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BARC.L"
                    android:textSize="10sp" />

                <TextView
                    android:id="@+id/tv_preview_change2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-7.5%"
                    android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/tv_preview_total2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="£1,850"
                    android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
