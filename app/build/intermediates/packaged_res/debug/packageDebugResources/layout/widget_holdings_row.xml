<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_hrow_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="11dp"
        android:paddingBottom="11dp">

        <!-- Col 1: Stock name + ticker (weight 1.5) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.5"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_hrow_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hw_text_primary"
                android:textSize="15sp"
                android:textFontWeight="600"
                android:fontFamily="@font/sora"
                android:letterSpacing="-0.01"
                android:singleLine="true"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_hrow_ticker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hw_text_muted"
                android:textSize="10.5sp"
                android:textFontWeight="500"
                android:fontFamily="@font/ibm_plex_mono"
                android:letterSpacing="0.03" />

        </LinearLayout>

        <!-- Col 2: Price (weight 0.95, right-aligned) -->
        <TextView
            android:id="@+id/tv_hrow_price"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.95"
            android:layout_marginStart="8dp"
            android:textColor="@color/hw_text_secondary"
            android:textSize="12.5sp"
            android:fontFamily="@font/ibm_plex_mono"
            android:gravity="end" />

        <!-- Col 3: Current value + cost basis (weight 1.05, right-aligned) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.05"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_hrow_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hw_text_strong"
                android:textSize="16sp"
                android:textFontWeight="600"
                android:fontFamily="@font/ibm_plex_mono"
                android:letterSpacing="-0.02"
                android:gravity="end" />

            <TextView
                android:id="@+id/tv_hrow_cost"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hw_text_faint"
                android:textSize="9.5sp"
                android:fontFamily="@font/ibm_plex_mono"
                android:gravity="end" />

        </LinearLayout>

        <!-- Col 4: Gain $ + Gain % (weight 1.0, right-aligned) -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_hrow_gain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hw_gain"
                android:textSize="13sp"
                android:textFontWeight="600"
                android:fontFamily="@font/ibm_plex_mono"
                android:gravity="end" />

            <TextView
                android:id="@+id/tv_hrow_gain_pct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/hw_gain"
                android:textSize="10sp"
                android:textFontWeight="500"
                android:fontFamily="@font/ibm_plex_mono"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Row divider -->
    <ImageView
        android:id="@+id/img_hrow_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/hw_divider_row"
        android:contentDescription="@null" />

</LinearLayout>
